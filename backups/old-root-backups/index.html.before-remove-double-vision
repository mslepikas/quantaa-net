<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Quantaa.net - Compute Intelligence Innovation</title>

  <style>
    :root {
      --bg: #03050a;
      --panel: rgba(255,255,255,0.045);
      --border: rgba(255,255,255,0.12);
      --text: #ffffff;
      --muted: rgba(255,255,255,0.72);
      --cyan: #00d4ff;
      --blue: #0077ff;
      --purple: #8a2be2;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Arial, Helvetica, sans-serif;
      overflow-x: hidden;
    }

    .page-bg {
      min-height: 100vh;
      background:
        linear-gradient(rgba(3,5,10,0.18), rgba(3,5,10,0.86)),
        url("public/images/backgrounds/quantaa-hero-background.png");
      background-size: cover;
      background-position: top center;
      background-repeat: no-repeat;
    }

    .container {
      width: min(1220px, calc(100% - 48px));
      margin: 0 auto;
    }

    header {
      height: 82px;
      display: flex;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      background: rgba(3,5,10,0.72);
      backdrop-filter: blur(14px);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      width: 100%;
    }

    .logo img {
      height: 38px;
      width: auto;
      display: block;
    }

    nav ul {
      display: flex;
      align-items: center;
      gap: 34px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    nav a {
      color: rgba(255,255,255,0.88);
      text-decoration: none;
      font-size: 15px;
      letter-spacing: 0.02em;
    }

    nav a:hover {
      color: var(--cyan);
    }

    .top-cta {
      color: #fff;
      text-decoration: none;
      padding: 12px 24px;
      border-radius: 999px;
      border: 1px solid var(--cyan);
      border-right-color: var(--purple);
      border-bottom-color: var(--purple);
      background: rgba(3,5,10,0.34);
      white-space: nowrap;
    }

    .hero {
      min-height: 520px;
      display: flex;
      align-items: center;
    }

    .hero-content {
      width: min(500px, 100%);
      padding-top: 20px;
    }

    h1 {
      margin: 0 0 26px;
      font-size: clamp(42px, 5.5vw, 72px);
      line-height: 1.08;
      font-weight: 400;
      letter-spacing: 0.045em;
    }

    h1 .white {
      display: block;
      color: #ffffff;
    }

    h1 .blue {
      display: block;
      color: var(--blue);
      text-shadow: 0 0 22px rgba(0,119,255,0.35);
    }

    h1 .purple {
      display: block;
      color: var(--purple);
      text-shadow: 0 0 22px rgba(138,43,226,0.35);
    }

    .hero p {
      color: rgba(255,255,255,0.82);
      font-size: 17px;
      line-height: 1.75;
      margin: 0 0 34px;
      max-width: 470px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      color: #fff;
      text-decoration: none;
      border: 1px solid var(--cyan);
      border-right-color: var(--purple);
      border-bottom-color: var(--purple);
      border-radius: 999px;
      padding: 14px 28px;
      background: rgba(3,5,10,0.36);
    }

    .main-section {
      padding: 46px 0 70px;
      background: linear-gradient(rgba(3,5,10,0.70), rgba(3,5,10,0.96));
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 1.65fr;
      gap: 60px;
      align-items: center;
    }

    .eyebrow {
      color: var(--cyan);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 14px;
      margin-bottom: 16px;
    }

    h2 {
      margin: 0 0 22px;
      font-size: clamp(30px, 4vw, 44px);
      line-height: 1.22;
      font-weight: 400;
      letter-spacing: 0.04em;
    }

    .about p {
      color: rgba(255,255,255,0.72);
      line-height: 1.75;
      font-size: 16px;
      margin: 0;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .card {
      min-height: 220px;
      padding: 34px 24px;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(255,255,255,0.035);
      text-align: center;
      box-shadow: 0 0 40px rgba(0,0,0,0.22);
    }

    .icon {
      width: 58px;
      height: 58px;
      margin: 0 auto 24px;
      display: grid;
      place-items: center;
      color: var(--cyan);
      font-size: 31px;
      border: 1px solid rgba(0,212,255,0.42);
      border-radius: 14px;
      box-shadow: inset 0 0 24px rgba(0,119,255,0.16);
    }

    .card:nth-child(2) .icon {
      color: var(--purple);
      border-color: rgba(138,43,226,0.52);
    }

    .card h3 {
      margin: 0 0 14px;
      font-weight: 500;
      font-size: 17px;
    }

    .card p {
      margin: 0;
      color: rgba(255,255,255,0.66);
      line-height: 1.65;
      font-size: 14px;
    }

    .stats {
      margin-top: 32px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(255,255,255,0.032);
      overflow: hidden;
    }

    .stat {
      padding: 28px 18px;
      text-align: center;
      border-right: 1px solid rgba(255,255,255,0.09);
    }

    .stat:last-child {
      border-right: 0;
    }

    .number {
      font-size: 38px;
      margin-bottom: 8px;
      background: linear-gradient(90deg, var(--cyan), var(--blue), var(--purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .label {
      color: rgba(255,255,255,0.72);
      font-size: 13px;
    }

    footer {
      padding: 28px 0;
      text-align: center;
      color: rgba(255,255,255,0.45);
      background: #03050a;
      border-top: 1px solid rgba(255,255,255,0.08);
      font-size: 14px;
    }

    @media (max-width: 950px) {
      nav ul {
        display: none;
      }

      .content-grid {
        grid-template-columns: 1fr;
      }

      .cards,
      .stats {
        grid-template-columns: 1fr;
      }

      .stat {
        border-right: 0;
        border-bottom: 1px solid rgba(255,255,255,0.09);
      }

      .stat:last-child {
        border-bottom: 0;
      }

      .hero {
        min-height: 560px;
      }
    }
  </style>
</head>

<body>
  <div class="page-bg">
    <header>
      <div class="container nav">
        <a class="logo" href="/" aria-label="Quantaa.net home">
          <img src="public/images/quantaa-logo-main.png" alt="Quantaa.net logo">
        </a>

        <nav>
          <ul>
            <li><a href="#about">About</a></li>
            <li><a href="#solutions">Solutions</a></li>
            <li><a href="#technology">Technology</a></li>
            <li><a href="#industries">Industries</a></li>
            <li><a href="#careers">Careers</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </nav>

        <a class="top-cta" href="#contact">Get Started →</a>
      </div>
    </header>

    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1>
            <span class="white">Compute.</span>
            <span class="blue">Intelligence.</span>
            <span class="purple">Innovation.</span>
          </h1>

          <p>
            Quantaa delivers cutting-edge AI solutions powered by advanced
            computing infrastructure and intelligent networking technologies.
          </p>

          <a class="button" href="#solutions">Explore Solutions →</a>
        </div>
      </div>
    </section>
  </div>

  <main class="main-section">
    <div class="container content-grid">
      <section class="about" id="about">
        <div class="eyebrow">About Quantaa</div>
        <h2>Pioneering the Future<br>of AI Infrastructure</h2>
        <p>
          At Quantaa, we build the intelligent foundation for tomorrow.
          Our advanced computing and networking solutions empower businesses
          to unlock the full potential of their data.
        </p>
      </section>

      <section class="cards" id="solutions">
        <article class="card">
          <div class="icon">▣</div>
          <h3>Advanced Compute</h3>
          <p>High-performance infrastructure designed for AI workloads at scale.</p>
        </article>

        <article class="card">
          <div class="icon">⌬</div>
          <h3>Intelligent Networking</h3>
          <p>Low-latency, high-throughput networks optimized for the future.</p>
        </article>

        <article class="card">
          <div class="icon">◌</div>
          <h3>AI Innovation</h3>
          <p>Innovative AI solutions that drive real-world business outcomes.</p>
        </article>
      </section>
    </div>

    <div class="container">
      <section class="stats">
        <div class="stat">
          <div class="number">10+</div>
          <div class="label">Years of Innovation</div>
        </div>

        <div class="stat">
          <div class="number">500+</div>
          <div class="label">Enterprise Clients</div>
        </div>

        <div class="stat">
          <div class="number">99.99%</div>
          <div class="label">Uptime Reliability</div>
        </div>

        <div class="stat">
          <div class="number">24/7</div>
          <div class="label">Expert Support</div>
        </div>
      </section>
    </div>
  </main>

  <footer id="contact">
    <div class="container">
      © 2026 Quantaa.net. Compute • Intelligence • Innovation.
    </div>
  </footer>
</body>
</html>
